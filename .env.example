# MamaDoc Django Front - environment example
#
# Copy this file to .env.local for local development.
# Do not put production MamaDoc/Supabase credentials here.

# Django API. Keep /api when using the Vite dev proxy below.
VITE_API_URL="/api"

# Local dev proxy target for /api.
# Use http://localhost:8000 when the Django backend is running locally,
# or https://newcrm.pediatr.kg when you want local frontend + dev server backend.
VITE_API_PROXY_TARGET="http://localhost:8000"

# Backend mode for migration work.
# Keep this set to django in this separate frontend copy.
VITE_BACKEND_MODE="django"

# Optional local settings
VITE_OFFICE_IP=""

# Подсказки адресов при вводе (форма пациента).
# Рекомендуемый вариант: Geoapify — бесплатный тариф 3000 запросов/день,
# регистрация без банковской карты. Ограничьте ключ по origin в кабинете.
# Получить ключ: https://myprojects.geoapify.com/
VITE_GEOAPIFY_API_KEY=""

# Альтернатива для собственного Nominatim-сервиса. Публичный
# nominatim.openstreetmap.org для autocomplete запрещён политикой сервиса.
#   VITE_OSM_NOMINATIM_URL — базовый URL self-hosted Nominatim.
#   VITE_OSM_COUNTRYCODES  — ISO-коды стран через запятую (по умолч. "kg";
#                            пусто = без ограничения).
#   VITE_OSM_LANG          — язык подписей (по умолч. "ru").
#   VITE_OSM_VIEWBOX       — "lonMin,latMin,lonMax,latMax" приоритет области.
#   VITE_OSM_EMAIL         — контактный email (вежливость к Nominatim).
VITE_OSM_NOMINATIM_URL=""
VITE_OSM_COUNTRYCODES="kg"
VITE_OSM_LANG="ru"
VITE_OSM_VIEWBOX=""
VITE_OSM_EMAIL=""
